IDD_ABOUTBOX DIALOGEX 0, 0, 550, 480
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About REFER..."
FONT 8, "MS Sans Serif", 0, 0, 0x0
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,15,7,21,20
    EDITTEXT        IDC_EDIT_VersionProgram,81,7,238,12,ES_READONLY | NOT WS_BORDER
    EDITTEXT        IDC_EDIT_VersionOpenGL,81,22,238,12,ES_READONLY | NOT WS_BORDER
    LTEXT           "DEVELOPED BY THE RESEARCH GROUP REGEO (www.regeo.uji.es)",IDC_STATIC,15,45,295,8,SS_NOPREFIX

    LTEXT           "REFER 1.0  resulted from the following capstone project:",IDC_STATIC,15,60,250,12
    LTEXT           "J.V. Andreu (2000). Desarrollo, implementación y prueba de un algoritmode reconstrucción de objetos \
                    a partir de una representación axonométrica,",IDC_STATIC,30,70,500,27
    LTEXT           " utilizando técnicas de optimización. Univ. Politecnica de Valencia",IDC_STATIC,30,80,350,27
    LTEXT           "- Implementation in C, in windows environment, of the optimization approach\
                    for line-drawing reconstruction proposed by Lipson and Shpitalni in 1996",IDC_STATIC,50,90,600,27

    LTEXT           "REFER 2.0 resulted from the following PhD Thesis:",IDC_STATIC,13,105,200,12
    LTEXT           "J. Conesa (2001). Reconstrucción Geométrica de sólidos utilizando técnicas de optimización. Univ. Politecnica de Cartagena",IDC_STATIC,31,115,400,19
    LTEXT           "- Improvements in the detection of regularities",IDC_STATIC,50,125,262,10
    LTEXT           "- Implementation and tuning of two variants of Simulated Annealing algorithms",IDC_STATIC,50,135,280,10
    LTEXT           "- Implementation of five direct inflation approaches: \
                    1) axonometric, 2) levels, 3) cavalier, 4) Marill's MSDA and 5) random",IDC_STATIC,50,145,500,11

    LTEXT           "REFER 3.0 resulted from the following PhD Thesis:",IDC_STATIC,13,160,200,13
    LTEXT           "A. Piquer (2003) Percepción artificial de dibujo lineales. Tesis Doctoral. Universitat Jaume I",IDC_STATIC,31,170,350,17
    LTEXT           "- Improvements in face detection (approach derived from Courter and Brewer's)",IDC_STATIC,50,180,262,12
    LTEXT           "- Bilateral symmetry detection in 2D line-drawings",IDC_STATIC,50,190,262,11
    LTEXT           "- 2D offline refinement by way of optimization",IDC_STATIC,50,200,262,11

    LTEXT           "REFER 4.0 was a non-published update done along 2004",IDC_STATIC,15,215,200,11
    LTEXT           "F. Naya added the sketching capability by way of CALI Library \
                    (MJ Fonseca et al. Cali: An online scribble recognizer for calligraphic interfaces (2002))",IDC_STATIC,30,225,520,12

    LTEXT           "REFER 5 was a major update, which started in 2009",IDC_STATIC,15,240,209,10
    LTEXT           "5.1 P. Company (2009) Update to C++ and MFC, plus new database",IDC_STATIC,30,250,230,10
    LTEXT           "5.2 P. Company (2010) Code structured by classes and new execution flow",IDC_STATIC,30,260,250,10
    LTEXT           "5.3 P.A.C. Varley and P. Company (2010) Finding Faces algorithm",IDC_STATIC,30,270,250,10
    LTEXT           "5.4 P. Company (2011) Adaptation of Corner detection approach by Xiong and LaViola",IDC_STATIC,30,280,280,10
    LTEXT           "5.5 P. Company and P.A.C. Varley (2011) Features detection",IDC_STATIC,30,290,250,10
    LTEXT           "5.6 P. Company and P.A.C. Varley (2012) Improvements in detection of cues",IDC_STATIC,30,300,250,10
    LTEXT           "5.7 P. Company, R. Plumed and P.A.C. Varley (2013) Sketch editor and vectorization module",IDC_STATIC,30,310,300,10
    LTEXT           "5.8 R. Plumed, P. Company and P.A.C. Varley (2013) Improvements in features detection",IDC_STATIC,30,320,280,10

    LTEXT           "REFER 6 resulted from the following PhD Thesis:",IDC_STATIC,15,335,209,10
    LTEXT           "R. Plumed (2014) Sobre la percepción de indicios en bocetos de ingeniería\
                    y su aplicación al modelado basado en bocetos. Tesis Doctoral. Universitat Jaume I",IDC_STATIC,30,345,500,27
    LTEXT           "6.1 Included a new vectorization code",IDC_STATIC,50,355,262,11
    LTEXT           "6.2 Included detection of vanishing points and grouping of parallel edges",IDC_STATIC,50,365,262,11
    LTEXT           "6.3 Included improvements on features detection",IDC_STATIC,50,375,250,10
    LTEXT           "6.4 Included improvements on bilateral symmetry detection in 2D line-drawings",IDC_STATIC,50,385,262,11
    LTEXT           "6.5 Included a new ""deconstruct"" method to obtain a 3D CSG model from a 2D engineering wireframe sketch  \
                    which depicts a polyhedral shape",IDC_STATIC,50,395,480,21

    LTEXT           "REFER 7 Included a general code review plus a major uptade of the help file, conducted by P. Company and J.D. Camba",IDC_STATIC,15,410,430,10

    LTEXT           "This program is free software,",IDC_STATIC,20,425,152,12
    LTEXT           "This program is distributed in the hope that it will be useful, but WITHOUT ANY WARRANTY;",IDC_STATIC,20,435,350,19
    LTEXT           "without even the implied warranty of MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.",IDC_STATIC,20,445,350,19
    DEFPUSHBUTTON   "Accept",IDOK,250,460,42,14,WS_GROUP
END

