IDD_DIALOG_MergeVertices DIALOG  0, 0, 365, 335
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Details of merging endpoints into vertices"
FONT 8, "MS Sans Serif"
BEGIN
    GROUPBOX        "Merge cubic corners (Disable when merging vertices with valence greater than three)",IDC_STATIC,7,5,350,70
    CONTROL         "Merge triplets of very close tips of isolated edges",
                    IDC_MERGE_CUBIC_CORNERS,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,20,15,200,14
    LTEXT           "Merge if distance is less than",IDC_STATIC,40,30,100,10
    EDITTEXT        IDC_DISTANCE_MERGE_CUBIC_CORNERS,140,28,25,15,ES_AUTOHSCROLL
    LTEXT           "pixels",IDC_STATIC,170,30,90,10
    CONTROL         "Merge only triplets of edges aligned to axes",
                    IDC_MERGE_ALIGNED_CUBIC_CORNERS,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,45,160,14
    LTEXT           "Edges are aligned to axes if they differ less than",IDC_STATIC,60,60,150,10
    EDITTEXT        IDC_COEF_MERGE_ROTATION_CUBIC_CORNERS,215,58,25,15,ES_AUTOHSCROLL
    LTEXT           "degrees",IDC_STATIC,245,60,30,11

    GROUPBOX        "Merge carefull lines",IDC_STATIC,7,85,350,70
    CONTROL         "Merge tips of careful lines",IDC_MERGE_CAREFUL_LINE_TIPS,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,20,95,110,14
    LTEXT           "Merge if distance is less than",IDC_STATIC,40,110,100,10
    EDITTEXT        IDC_COEF_MERGE_VERTICES,140,108,25,15,ES_AUTOHSCROLL
    LTEXT           "% of the length of the line",IDC_STATIC,170,110,90,10
    LTEXT           "Do not merge if line must rotate more than ",IDC_STATIC,40,125,145,10
    EDITTEXT        IDC_COEF_MERGE_ROTATION,180,123,20,15,ES_AUTOHSCROLL
    LTEXT           "degrees",IDC_STATIC,205,125,30,11
    LTEXT           "Minimum merit for reificated vertices ",IDC_STATIC,40,140,130,10
    EDITTEXT        IDC_REIFICATION_MERIT,160,138,20,15,ES_AUTOHSCROLL
    //LTEXT           "in the range [0, 1]",IDC_STATIC,310,140,50,10

    GROUPBOX        "Merge casual lines",IDC_STATIC,7,160,350,150
    CONTROL         "Merge tips of casual lines",IDC_MERGE_CASUAL_LINE_TIPS,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,20,170,110,14

    LTEXT           "Tolerance for junctions inside lines ",IDC_STATIC,30,185,120,10
    EDITTEXT        IDC_MERGE_CASUAL_INTOL,150,183,25,15,ES_AUTOHSCROLL
    LTEXT           "% of the length of the line",IDC_STATIC,180,185,105,10
    LTEXT           "Tolerance for junctions outside lines ",IDC_STATIC,30,200,120,10
    EDITTEXT        IDC_MERGE_CASUAL_OUTTOL,150,198,25,15,ES_AUTOHSCROLL
    LTEXT           "% of the length of the line",IDC_STATIC,180,200,105,10

    CONTROL         "Re-merge tips of triplets of lines",IDC_REMERGE_TRIPLETS,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,215,110,14

    LTEXT           "Merge triplets of lines if distance is less than ",IDC_STATIC,60,230,170,10
    EDITTEXT        IDC_COEF_REMERGE_TRIPLETS,205,228,25,15,ES_AUTOHSCROLL
    LTEXT           "% of the average length of the lines",IDC_STATIC,235,230,120,10

    LTEXT           "Maximum merit for emergent triplets of vertices ",IDC_STATIC,60,245,160,10
    EDITTEXT        IDC_EMERGENCE_TRIPLETS_MERIT,210,243,25,15,ES_AUTOHSCROLL

    CONTROL         "Re-merge dangling lines",IDC_REMERGE_DANGLING,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,260,110,14
    LTEXT           "Merge dangling lines if distance is less than ",IDC_STATIC,60,275,170,10
    EDITTEXT        IDC_COEF_REMERGE_DANGLING,205,273,25,15,ES_AUTOHSCROLL
    LTEXT           "% of the length of the line",IDC_STATIC,235,275,80,10

    LTEXT           "Maximum reduction in the merit for vertices with dangling lines ",IDC_STATIC,60,290,240,10
    EDITTEXT        IDC_EMERGENCE_DANGLING_MERIT,260,288,25,15,ES_AUTOHSCROLL

    DEFPUSHBUTTON   "Accept",IDOK,14,315,50,14
    PUSHBUTTON      "Restore default values",IDC_R2D_RestoreDefault,140,315,100,14
    PUSHBUTTON      "Cancel",IDCANCEL,300,315,50,14
END

