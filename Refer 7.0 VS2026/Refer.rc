    PUSHBUTTON      "Details",IDC_DetailsRegularitiesCost,140,168,35,12

    DEFPUSHBUTTON   "Accept",IDOK,7,195,45,15
    PUSHBUTTON      "Restore default values",IDC_BUTTON_RestoreDefault,55,195,75,15
    PUSHBUTTON      "Cancel",IDCANCEL,135,195,45,15
END

