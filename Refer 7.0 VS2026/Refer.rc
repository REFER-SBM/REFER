IDD_DIALOG_ConfigCSG DIALOGEX 0, 0, 280, 210
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Configure Constructive Solid Geometry"
FONT 8, "MS Sans Serif", 0, 0, 0x0
BEGIN
    CONTROL         "Build CSG model",IDC_CSG_Build_CSG,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,10,79,8

    CONTROL         "Inflate 3D BRep features",IDC_CSG_Inflation,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,45,25,110,10
    CONTROL         "Direct inflation (WARNING: Does not inflate subgraphs!)",IDC_CSG_Inflation_Direct,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,55,35,220,10
    CONTROL         "Optimization inflation (WARNING: is time consuming!)",IDC_CSG_Inflation_Optimization,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,55,45,200,10

    LTEXT           "Features below a minimum threshold merit of",IDC_STATIC,45,65,170,8
    EDITTEXT        IDC_CSG_ThresholdFMerit,190,63,27,12,ES_AUTOHSCROLL
    LTEXT           "are discarded",IDC_STATIC,220,65,60,8
    LTEXT           "Datums below a minimum threshold merit of",IDC_STATIC,45,80,170,8
    EDITTEXT        IDC_CSG_ThresholdDMerit,190,78,27,12,ES_AUTOHSCROLL
    LTEXT           "are discarded",IDC_STATIC,220,80,60,8

    LTEXT           "Threshold for angular imperfections",IDC_STATIC,45,95,110,8
    EDITTEXT        IDC_CSG_ThresholdAngle,160,93,27,12,ES_AUTOHSCROLL
    LTEXT           "degrees",IDC_STATIC,190,95,60,8

    LTEXT           "Threshold for alignment offset",IDC_STATIC,45,110,110,8
    EDITTEXT        IDC_CSG_ThresholdOffset,145,108,27,12,ES_AUTOHSCROLL
    LTEXT           "% of the length",IDC_STATIC,175,110,80,8

    LTEXT           "Threshold for location imperfections",IDC_STATIC,45,125,115,8
    EDITTEXT        IDC_CSG_ThresholdLocation,165,123,27,12,ES_AUTOHSCROLL
    LTEXT           "units",IDC_STATIC,195,125,60,8

    GROUPBOX        "Calculate orthodistances of datums:",IDC_STATIC,45,140,150,35
    CONTROL         "Use only main origin",IDC_CSG_UseMultipleOrigins,
                    "Button",BS_AUTORADIOBUTTON | WS_GROUP,65,150,110,14
    CONTROL         "Use main plus local origins",IDC_RADIO1,
                    "Button",BS_AUTORADIOBUTTON,65,160,100,14

    DEFPUSHBUTTON   "Accept",IDOK,5,185,49,15
    PUSHBUTTON      "Restore default values",IDC_BUTTON_RestoreDefault,95,185,85,15
    PUSHBUTTON      "Cancel",IDCANCEL,220,185,51,15
END


IDD_DIALOG_DetailsHillClimbing DIALOG  0, 0, 315, 235
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Details of Hill Climbing optimization"
FONT 8, "MS Sans Serif"
BEGIN
    GROUPBOX        "INCREMENTS OF VARIABLES",IDC_STATIC,7,7,303,122
    CONTROL         "Parametric",IDC_RADIO_StyleIncrement,"Button",BS_AUTORADIOBUTTON | WS_GROUP,13,17,113,8
    CONTROL         "Prefixed",IDC_RADIO1,"Button",BS_AUTORADIOBUTTON,13,75,113,8

    CONTROL         "User",IDC_RADIO_IncrementoPrefijado,"Button",BS_AUTORADIOBUTTON | WS_GROUP,26,87,105,8
    CONTROL         "Marill",IDC_RADIO2,"Button",BS_AUTORADIOBUTTON,26,101,104,8
    CONTROL         "Leclerc and Fischler",IDC_RADIO3,"Button",BS_AUTORADIOBUTTON,26,115,105,8

    LTEXT           "Length of initial step",IDC_STATIC,27,29,77,8
    EDITTEXT        IDC_EDIT_LengthInitialStepHC,109,27,22,12,ES_AUTOHSCROLL
    LTEXT           "% min( Range X, Range Y )",IDC_STATIC,137,29,87,8

    LTEXT           "Step reduction: New step",IDC_STATIC,27,44,107,8
    EDITTEXT        IDC_EDIT_LengthStepReduction,115,42,22,12,ES_AUTOHSCROLL
    LTEXT           "% from current",IDC_STATIC,145,44,46,9

    LTEXT           "Length of the final step",IDC_STATIC,28,60,74,9
    EDITTEXT        IDC_EDIT_LengthFinalStep,109,58,22,12,ES_AUTOHSCROLL
    LTEXT           "% min( Range X, Range Y )",IDC_STATIC,137,60,87,8

    CTEXT           "Level / Step length",IDC_STATIC,220,18,85,8
    EDITTEXT        IDC_EDIT_IncrementsOfVariables,227,28,75,91,ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL

    GROUPBOX        "STOP CRITERION",IDC_STATIC,7,133,303,51
    LTEXT           "Max steps for every level",IDC_STATIC,13,145,100,10
    EDITTEXT        IDC_EDIT_NumeroMaximoIteraciones,100,143,26,12,ES_AUTOHSCROLL
    LTEXT           "x Number of variables",IDC_STATIC,130,145,74,10

    LTEXT           "Skip level if best solution found so far does not reduce the cost at least",IDC_STATIC,13,158,257,8
    EDITTEXT        IDC_EDIT_ThresholdRejectBestCostInLevel,245,156,27,12,ES_AUTOHSCROLL
    LTEXT           "%",IDC_STATIC,275,158,8,9
    LTEXT           "End if best solution found so far does not reduce the cost at least",IDC_STATIC,13,171,239,8
    EDITTEXT        IDC_EDIT_ThresholdRejectBestCost,230,169,27,12,ES_AUTOHSCROLL
    LTEXT           "%",IDC_STATIC,265,171,8,9

    PUSHBUTTON      "Recommended parameters",IDC_DetailsRestoreValues,110,188,100,15

    DEFPUSHBUTTON   "Accept",IDOK,35,210,50,14
    PUSHBUTTON      "Restore default values",IDC_BUTTON_RestoreDefault,100,210,115,15
    PUSHBUTTON      "Cancel",IDCANCEL,230,210,50,14
END

