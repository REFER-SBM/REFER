IDD_DIALOG_SettingsRefer DIALOGEX 0, 0, 245, 445
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "General settings"
FONT 8, "MS Sans Serif", 0, 0, 0x0
BEGIN
    CONTROL         "Online refine",IDC_REFER_Refine_On_Line,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,5,114,10
    CONTROL         "Offline refine",IDC_REFER_Refine_Off_Line,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,15,114,10
    CONTROL         "Detect cues and features",IDC_REFER_Detect_CuesAndFeatures,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,25,114,10

    CONTROL              "Detect cues",IDC_REFER_Detect_Cues,
                         "Button",BS_AUTOCHECKBOX | WS_TABSTOP,30,35,114,10
     CONTROL                 "Detect valences",IDC_REFER_Detect_Valences,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,45,114,10
     CONTROL                 "Detect parallel edges",IDC_REFER_Detect_ParallelEdges,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,55,114,10
     CONTROL                 "Detect vanishing points",IDC_REFER_Detect_VanishingPoints,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,65,114,10
     CONTROL                 "Detect graphs",IDC_REFER_Detect_Graphs,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,75,114,10
     CONTROL                 "Detect perimeter",IDC_REFER_Detect_Perimeter,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,85,114,10
     CONTROL                 "Detect labels",IDC_REFER_Detect_Labels,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,95,114,10
     CONTROL                 "Detect main axes",IDC_REFER_Detect_MainAxes,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,105,114,10
     CONTROL                 "Detect faces",IDC_REFER_Detect_Faces,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,115,114,10
     CONTROL                 "Detect typology",IDC_REFER_Detect_Typology,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,125,114,10
     CONTROL                 "Detect hidden edges",IDC_REFER_Detect_HiddenEdges,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,135,114,10
     CONTROL                 "Detect symmetry",IDC_REFER_Detect_Symmetry,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,145,114,10
     CONTROL                 "Detect levels",IDC_REFER_Detect_Levels,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,155,114,10

    CONTROL              "Detect features",IDC_REFER_Detect_Features,
                         "Button",BS_AUTOCHECKBOX | WS_TABSTOP,30,165,114,10
    CONTROL                 "Detect ribs and dividers",IDC_REFER_Detect_RibsAndDividers,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,175,114,10
    CONTROL                 "Detect rails and slots",IDC_REFER_Detect_RailsAndSlots,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,185,114,10
    CONTROL                 "Detect steps and pockets",IDC_REFER_Detect_StepsAndPockets,
                            "Button",BS_AUTOCHECKBOX | WS_TABSTOP,40,195,114,10

    CONTROL         "BRep Inflation",IDC_REFER_InflateBRep,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,205,114,10
    CONTROL              "Direct Inflation",IDC_REFER_Direct_Inflation,
                         "Button",BS_AUTOCHECKBOX | WS_TABSTOP,30,215,114,10
    CONTROL              "Optimization Inflation",IDC_REFER_Optimization_based_Inflation,
                         "Button",BS_AUTOCHECKBOX | WS_TABSTOP,30,225,114,10
    CONTROL         "3D Refine",IDC_REFER_Refine_3D,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,235,114,10
    CONTROL         "3D Tessellate",IDC_REFER_Tessellate_3D,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,245,114,10
    CONTROL         "CSG Modeling",IDC_REFER_CSG_Modeling,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,255,114,10

    LTEXT           "Save IGS files as:",IDC_STATIC,15,275,60,10
    CONTROL         "Type 143 surface",IDC_IGS_TYPE_143,"Button",BS_AUTORADIOBUTTON | WS_GROUP,30,285,70,10
    CONTROL         "Type 144 surface",IDC_RADIO2,"Button",BS_AUTORADIOBUTTON,30,295,70,10

    LTEXT           "Save IGS files as:",IDC_STATIC,15,305,60,10
    CONTROL         "Polygonal faces",IDC_IGS_NGON_FACES,"Button",BS_AUTORADIOBUTTON | WS_GROUP,30,315,70,10
    CONTROL         "Triangular meshes",IDC_RADIO12,"Button",BS_AUTORADIOBUTTON,30,325,70,10

    GROUPBOX        "Settings requiring restart", IDC_STATIC, 7, 340, 230, 80

    LTEXT           "Show                 most recently used (MRU) files", IDC_STATIC, 15, 355, 150, 10
    EDITTEXT        IDC_REFER_MRU_Files, 40, 354, 20, 13, ES_AUTOHSCROLL

    LTEXT           "Toolbar buttons size                  (0 for default, 1,2,3,... for scale)", IDC_STATIC, 15, 370, 200, 10
    EDITTEXT        IDC_REFER_toolbarButtonsSize, 85, 369, 20, 13, ES_AUTOHSCROLL

    LTEXT           "Data folder", IDC_STATIC, 15, 385, 200, 10
    EDITTEXT        IDC_REFER_PathINI, 70, 384, 160, 13, ES_AUTOHSCROLL

    LTEXT           "Examples folder", IDC_STATIC, 15, 400, 200, 10
    EDITTEXT        IDC_REFER_PathExamples, 70, 399, 160, 13, ES_AUTOHSCROLL

    DEFPUSHBUTTON   "Save Settings",IDOK,7,425,77,14
    PUSHBUTTON      "Cancel",IDCANCEL,185,425,50,14
END

