IDD_DIALOG_Details_StrokeVectorize DIALOGEX 0, 0, 375, 450
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "FitLines Details Configuration"
FONT 8, "MS Sans Serif", 0, 0, 0x0
BEGIN
    CONTROL         "Detect straight lines",IDC_VectorizeLines,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,5,10,80,10

    GROUPBOX        "Straight line detection parameters",IDC_STATIC,15,25,350,175

    GROUPBOX        "Fitting straight line approach",IDC_STATIC,25,40,335,75
    CONTROL         "Regression line",IDC_EDIT_FitLineApproach,"Button",BS_AUTORADIOBUTTON | WS_GROUP,55,55,65,13
    CONTROL         "Connect stroke tips",IDC_RADIO1,"Button",BS_AUTORADIOBUTTON,55,70,75,13

    CONTROL         "Remove irregular tails of strokes",
                    IDC_EDIT_RemoveTails,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,150,70,120,10
    LTEXT           "Remove up to ",IDC_STATIC,150,85,50,13
    EDITTEXT        IDC_EDIT_MaxTrimPointsInTail,200,83,35,13,ES_AUTOHSCROLL
    LTEXT           "points in each tail",IDC_STATIC,240,85,60,13
    LTEXT           "Remove tails rotated at least ",IDC_STATIC,150,100,120,13
    EDITTEXT        IDC_EDIT_MinAngleInTail,245,98,35,13,ES_AUTOHSCROLL
    LTEXT           "degrees",IDC_STATIC,290,100,25,13

    GROUPBOX        "Merit parameters for straight lines",IDC_STATIC,25,120,335,75

    LTEXT           "Minimum tolerance: width of the tolerance strip lower than",IDC_STATIC,30,135,230,13
    EDITTEXT        IDC_EDIT_LineTolMin,220,133,35,13,ES_AUTOHSCROLL
    LTEXT           "% of the stroke's length",IDC_STATIC,260,135,80,13
    LTEXT           "Maximum tolerance: width of the tolerance strip greater than",IDC_STATIC,30,150,230,13
    EDITTEXT        IDC_EDIT_LineTolMax,225,148,35,13,ES_AUTOHSCROLL
    LTEXT           "% of the stroke's length",IDC_STATIC,265,150,80,13
    LTEXT           "Penalty for smoothing strokes",IDC_STATIC,30,165,110,13
