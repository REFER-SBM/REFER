IDD_DIALOG_Details_RibsAndDividers DIALOG  0, 0, 310, 165
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Details on detection of ribs and dividers"
FONT 8, "MS Sans Serif"
BEGIN
    GROUPBOX        "Thresholds for slender faces",IDC_STATIC,7,5,295,50
    LTEXT           "Threshold for short edges",IDC_STATIC,10,20,120,10
    EDITTEXT        IDC_Ribs_ThresholdShort,100,20,28,13,ES_AUTOHSCROLL
    LTEXT           "times the size of the bounding box of the drawing",IDC_STATIC,140,20,160,11
    LTEXT           "Threshold for long edges",IDC_STATIC,10,35,240,10
    EDITTEXT        IDC_Ribs_ThresholdLong,100,35,28,13,ES_AUTOHSCROLL
    LTEXT           "times the size of the related short edges",IDC_STATIC,140,35,140,11

