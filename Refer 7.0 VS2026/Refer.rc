IDD_DIALOG_Symmetry DIALOGEX 0, 0, 490, 275
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Bilateral Symmetry Configuration"
FONT 8, "MS Sans Serif", 0, 0, 0x0
BEGIN
    CONTROL         "Discard circuits where the orientations of any of the crossed edges diverges more than",
                    IDC_SYM_DetectNormalCrossing,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,15,290,11
    EDITTEXT        IDC_SYM_MaxParallelCrossing,305,13,32,14,ES_AUTOHSCROLL
    LTEXT           "degrees from each other",IDC_STATIC,340,15,80,11
    LTEXT           "Accept as perfectly parallel edges that diverge less than ",IDC_STATIC,30,30,210,11
    EDITTEXT        IDC_SYM_MinParallelCrossing,220,28,32,14,ES_AUTOHSCROLL
    LTEXT           " degrees from each other",IDC_STATIC,255,30,90,11
    LTEXT           "Merit of parallel crossing edges ",IDC_STATIC,30,45,130,11
    EDITTEXT        IDC_SYM_MeritWeight_1,135,43,32,14,ES_AUTOHSCROLL
    LTEXT           "%",IDC_STATIC,170,45,10,11

    CONTROL         "Discard symmetry axes if distance between symmetric vertices is distorded more than",
                    IDC_SYM_DetectDistorted,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,60,275,11
    EDITTEXT        IDC_SYM_MaxSymDistortion,300,58,32,14,ES_AUTOHSCROLL
    LTEXT           "% of the maximum dimension of the face",IDC_STATIC,335,60,130,11
    LTEXT           "Accept as perfectly symmetric vertices with positions distorted less than ",IDC_STATIC,30,75,240,11
    EDITTEXT        IDC_SYM_MinSymDistortion,260,73,32,14,ES_AUTOHSCROLL
    LTEXT           " % of the maximum dimension of the face",IDC_STATIC,295,75,160,11

    LTEXT          "Discard circuits where the orientations of any of the face symmetry lines diverges more than",IDC_STATIC,30,90,320,11
    EDITTEXT        IDC_SYM_MaxParallelFaceSymLines,325,88,32,14,ES_AUTOHSCROLL
    LTEXT           "degrees from each other",IDC_STATIC,370,90,80,11
    LTEXT           "Accept as perfectly parallel face symmetry lines that diverge less than ",IDC_STATIC,30,105,240,11
    EDITTEXT        IDC_SYM_MinParallelFaceSymLines,275,103,32,14,ES_AUTOHSCROLL
    LTEXT           " degrees from each other",IDC_STATIC,310,105,90,11

    LTEXT           "Merit of skewed symmetry axes ",IDC_STATIC,30,120,110,11
    EDITTEXT        IDC_SYM_MeritWeight_2,135,118,32,14,ES_AUTOHSCROLL
    LTEXT           "%",IDC_STATIC,170,120,10,11

    CONTROL         "Discard circuits where the orientations of any of the edge symmetry lines diverges more than",
                    IDC_SYM_SymmetricalEdges,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,135,300,11
    EDITTEXT        IDC_SYM_MaxParallelEdgeSymLines,320,133,32,14,ES_AUTOHSCROLL
    LTEXT           "degrees from each other",IDC_STATIC,355,135,80,11
    LTEXT           "Accept as parallel edge symmetry lines that diverge less than ",IDC_STATIC,30,150,220,11
    EDITTEXT        IDC_SYM_MinParallelEdgeSymLines,235,148,32,14,ES_AUTOHSCROLL
    LTEXT           " degrees from each other",IDC_STATIC,275,150,90,11
    LTEXT           "Merit of symmetrical edges ",IDC_STATIC,30,165,90,11
    EDITTEXT        IDC_SYM_MeritWeight_3,120,163,32,14,ES_AUTOHSCROLL
    LTEXT           "%",IDC_STATIC,155,165,10,11

    CONTROL         "Prioritize vertical symmetry planes (containing sides that deviate from vertical less than ",
                    IDC_SYM_PrioritizeVertical,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,180,280,11
    EDITTEXT        IDC_SYM_minVerticalThreshold,305,178,25,14,ES_AUTOHSCROLL
    LTEXT           ", or up to",IDC_STATIC,335,180,40,11
    EDITTEXT        IDC_SYM_maxVerticalThreshold,370,178,25,14,ES_AUTOHSCROLL
    LTEXT           "degrees)",IDC_STATIC,400,180,40,11
    LTEXT           "Merit of vertical symmetry planes ",IDC_STATIC,30,195,150,11
    EDITTEXT        IDC_SYM_MeritWeight_4,145,193,32,14,ES_AUTOHSCROLL
    LTEXT           "%",IDC_STATIC,180,195,10,11

    CONTROL         "Discard circuits with total merit less than ",
                    IDC_SYM_RemoveBadMerit,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,15,215,145,11
    EDITTEXT        IDC_SYM_MinMerit,165,213,32,14,ES_AUTOHSCROLL
    LTEXT           "(merits are in the range [1, -1])",IDC_STATIC,205,215,140,11

    PUSHBUTTON      "Restore default values",IDC_BUTTON_DetailsSymmetryDefault,180,255,80,14
    DEFPUSHBUTTON   "Accept",IDOK,10,255,35,14
    PUSHBUTTON      "Cancel",IDCANCEL,440,255,35,14
END


