IDD_DIALOG_ConfigOptimizationInflation DIALOGEX 0, 0, 190, 215
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Optimization-Based Inflation Configuration"
FONT 8, "MS Sans Serif", 0, 0, 0x0
BEGIN
    GROUPBOX        "Optimization Algorithm",IDC_STATIC,10,10,170,55
    CONTROL         "Hill-Climbing",IDC_RADIO_OptimizationAlgorithm,"Button",BS_AUTORADIOBUTTON | WS_GROUP,15,20,93,13
    CONTROL         "Simulated Annealing",IDC_RADIO1,"Button",BS_AUTORADIOBUTTON,15,35,93,13
    CONTROL         "Simulated Annealing Multicriteria",IDC_RADIO2,"Button",BS_AUTORADIOBUTTON,15,50,115,13
    PUSHBUTTON      "Details",IDC_DetailsHillClimbing,140,18,35,13
    PUSHBUTTON      "Details",IDC_DetailsSimulatedAnnealing,140,33,35,13
    PUSHBUTTON      "Details",IDC_DetailsSimulatedAnnealingMulti,140,48,35,13

    GROUPBOX        "Regularities",IDC_STATIC,10,70,170,70
    CONTROL         "Derived from the model's typology",IDC_RADIO_SelectRegularities,
                    "Button",BS_AUTORADIOBUTTON | WS_GROUP,15,80,120,12
    CONTROL         "Fixed by the user",IDC_RADIO3,"Button",BS_AUTORADIOBUTTON,15,95,82,12
    PUSHBUTTON      "Details",IDC_DetailsRegularitiesNature,140,78,35,13
    PUSHBUTTON      "Details",IDC_DetailsRegularitiesUser,140,93,35,13

    LTEXT           "Assimilate compared angles as equal",IDC_STATIC,30,115,130,11
