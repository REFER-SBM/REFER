IDD_DIALOG_DetailsTypology DIALOG  0, 0, 455, 175
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Details of typology detection"
FONT 8, "MS Sans Serif"
BEGIN
    GROUPBOX        "OBJECT'S TYPOLOGY",IDC_STATIC,7,7,440,85
    LTEXT           "Object NORMALON (or QUASI) if all (or nearly all) edges are aligned with one of the three main perpendicular axes",IDC_STATIC,13,25,370,12
    LTEXT           "Object PYRAMIDAL if one vertex is connected to all the others, which are connected to three, and only three, edges",IDC_STATIC,13,40,370,12
    LTEXT           "Object PRISMATIC if the number of parallel edges is greater than",IDC_STATIC,13,55,257,12
    EDITTEXT        IDC_EDIT_Min_Frequency_Prismatic_Objects,230,53,25,12,ES_AUTOHSCROLL
    LTEXT           "%",IDC_STATIC,260,55,9,12
    LTEXT           "the number of vertices",IDC_STATIC,270,55,86,10
    LTEXT           "Object UNDEFINED_D if the number of edges parallel to any of the main axes is greater than",IDC_STATIC,13,70,308,12
    EDITTEXT        IDC_EDIT_Min_Frequency_Undefined_Objects_D,310,68,25,12,ES_AUTOHSCROLL
    LTEXT           "%",IDC_STATIC,340,70,9,12
    LTEXT           "of the total number of edges",IDC_STATIC,348,70,90,10

    GROUPBOX        "GENERAL PARAMETERS",IDC_STATIC,7,100,440,45
    LTEXT           "Consider edges as parallel if they differ less than",IDC_STATIC,13,115,177,12
    EDITTEXT        IDC_EDIT_ThresholdForParallel,170,113,25,12,ES_AUTOHSCROLL
    LTEXT           "degrees",IDC_STATIC,200,115,30,12
    LTEXT           "Consider faces similar if their areas differ less than",IDC_STATIC,13,130,177,12
    EDITTEXT        IDC_EDIT_ThresholdForArea,170,128,25,12,ES_AUTOHSCROLL
    LTEXT           "%",IDC_STATIC,200,130,10,12

    DEFPUSHBUTTON   "Accept",IDOK,7,155,50,14
    PUSHBUTTON      "Restore default values",IDC_BUTTON_RestoreDefault,180,155,112,14
    PUSHBUTTON      "Cancel",IDCANCEL,390,155,50,14
END

