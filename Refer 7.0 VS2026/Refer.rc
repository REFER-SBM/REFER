IDD_DIALOG_Details_ParallelEdges DIALOG  0, 0, 245, 140
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Details on parallel edges detection"
FONT 8, "MS Sans Serif"
BEGIN
    GROUPBOX        "APPROACH TO DETECT PARALLEL EDGES",IDC_STATIC,7,7,230,100
    CONTROL         "Automatic",IDC_PE_ParallelEdgesApproach,"Button",BS_AUTORADIOBUTTON | WS_GROUP,10,20,50,14
    CONTROL         "Vanishing points",IDC_RADIO1,"Button",BS_AUTORADIOBUTTON,10,60,70,14
    CONTROL         "Angular distribution",IDC_RADIO2,"Button",BS_AUTORADIOBUTTON,10,75,75,14

    LTEXT           "(Uses Angular distribution for normalon objects",IDC_STATIC,30,35,200,10
    LTEXT           "in parallel projection and Vanishing points otherwise)",IDC_STATIC,30,45,200,10
    PUSHBUTTON      "Details",IDC_PE_DetailsVanishingPoints,85,60,35,13
    LTEXT           "Threshold to accept that lines are parallel",IDC_STATIC,30,90,170,10
    EDITTEXT        IDC_PE_TolForParallel,170,88,28,13,ES_AUTOHSCROLL
    LTEXT           "degrees",IDC_STATIC,200,90,25,11
    DEFPUSHBUTTON   "Accept",IDOK,10,115,50,14
    PUSHBUTTON      "Restore default values",IDC_VPs_RestoreDefault,70,115,95,15
    PUSHBUTTON      "Cancel",IDCANCEL,180,115,50,14
END

IDD_DIALOG_Details_VanishingPoints DIALOG  0, 0, 415, 125
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Details on vanishing points detection"
FONT 8, "MS Sans Serif"
BEGIN
    LTEXT           "Maximum angle to cluster together two clusters of vanishing points (VP)",IDC_STATIC,10,10,240,10
    EDITTEXT        IDC_VPs_ClusteringAngle,245,10,28,13,ES_AUTOHSCROLL
    LTEXT           "degrees",IDC_STATIC,280,10,30,11
    LTEXT           "Inner radius of the ring to detect VPs",IDC_STATIC,10,25,120,10
    EDITTEXT        IDC_VPs_InRing,135,25,28,13,ES_AUTOHSCROLL
    LTEXT           "times the radius of the bounding ring of the drawing",IDC_STATIC,170,25,170,11
    LTEXT           "Outer radius of the ring to detect VPs",IDC_STATIC,10,40,120,10
    EDITTEXT        IDC_VPs_OutRing,135,40,28,13,ES_AUTOHSCROLL
    LTEXT           "times the radius of the bounding ring of the drawing",IDC_STATIC,170,40,170,11
    LTEXT           "Tolerance radius to accept two endpoints as coincident",IDC_STATIC,10,55,200,10
    EDITTEXT        IDC_VPs_ToleranceCoincident,190,55,35,13,ES_AUTOHSCROLL
    LTEXT           "times the length of the edges",IDC_STATIC,230,55,100,11
    LTEXT           "Tolerance angle to accept two consecutive lines as collinear",IDC_STATIC,10,70,200,10
    EDITTEXT        IDC_VPs_ToleranceParallel,210,70,28,13,ES_AUTOHSCROLL
    LTEXT           "degrees",IDC_STATIC,240,70,30,11
    LTEXT           "Minimum dispersion to accept that lines of a bundle are parallel",IDC_STATIC,10,85,200,10
    EDITTEXT        IDC_VPs_ToleranceDispersion,215,85,28,13,ES_AUTOHSCROLL
    LTEXT           "times the radius of the bounding ring of the drawing",IDC_STATIC,245,85,170,11
    DEFPUSHBUTTON   "Accept",IDOK,20,105,50,14
    PUSHBUTTON      "Restore default values",IDC_VPs_RestoreDefault,150,105,116,15
    PUSHBUTTON      "Cancel",IDCANCEL,340,105,50,14
END

